---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import BlogCard from '../components/BlogCard.astro';
import Tags from '../components/Tags.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const featuredPost = posts.find(post => post.data.featured) || posts[0];
const regularPosts = posts.filter(post => post !== featuredPost);
---
<Layout title="Blogs" description="Technical insights on AI research, ML implementation, and high-performance software engineering.">
  <div>
    <!-- HERO BLOG -->
    <section class="pt-36 pb-16 relative overflow-hidden">
      <div class="absolute top-0 right-0 w-80 h-80 bg-accent/10 rounded-full blur-3xl pointer-events-none" aria-hidden="true"></div>
      <div class="max-w-6xl mx-auto px-6 relative z-10">
        <p class="reveal text-xs font-medium text-accent tracking-widest uppercase mb-3">Writing</p>
        <h1 class="reveal reveal-delay-1 font-display font-bold text-5xl md:text-6xl text-zinc-900 dark:text-white leading-tight mb-4">The Blog</h1>
        <p class="reveal reveal-delay-2 text-lg text-zinc-500 dark:text-zinc-400 max-w-xl leading-relaxed">Technical insights on AI research, ML implementation, and high-performance software engineering.</p>

        <!-- Filter tags -->
        <div class="reveal reveal-delay-3 flex flex-wrap gap-2 mt-8">
          <button data-filter="all" class="blog-filter-btn bg-accent text-white border-accent text-sm px-4 py-1.5 rounded-full border transition-colors">All</button>
          <button data-filter="design" class="blog-filter-btn bg-white dark:bg-zinc-900 text-zinc-600 dark:text-zinc-400 border-zinc-200 dark:border-zinc-700 hover:border-accent text-sm px-4 py-1.5 rounded-full border transition-colors">Design</button>
          <button data-filter="dev" class="blog-filter-btn bg-white dark:bg-zinc-900 text-zinc-600 dark:text-zinc-400 border-zinc-200 dark:border-zinc-700 hover:border-accent text-sm px-4 py-1.5 rounded-full border transition-colors">Dev</button>
          <button data-filter="freelance" class="blog-filter-btn bg-white dark:bg-zinc-900 text-zinc-600 dark:text-zinc-400 border-zinc-200 dark:border-zinc-700 hover:border-accent text-sm px-4 py-1.5 rounded-full border transition-colors">Freelance</button>
        </div>
      </div>
    </section>

    <!-- FEATURED ARTICLE -->
    {featuredPost && (
      <section class="pb-16 blog-article-wrapper" data-category={featuredPost.data.category}>
        <div class="max-w-6xl mx-auto px-6">
          <a href={`/blog/${featuredPost.id}`} class="group block rounded-3xl overflow-hidden bg-zinc-50 dark:bg-zinc-900 border border-zinc-100 dark:border-zinc-800 hover:border-accent transition-colors">
            <div class="grid md:grid-cols-2">
              <div class="photo-frame h-64 md:h-auto">
                <img src={featuredPost.data.image} alt={featuredPost.data.title} loading="lazy"/>
              </div>
              <div class="p-8 md:p-12 flex flex-col justify-center">
                <div class="flex items-center gap-3 mb-4">
                  <Tags tags={featuredPost.data.tags} />
                  <span class="text-xs text-zinc-400">{featuredPost.data.pubDate.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</span>
                </div>
                <h2 class="font-display font-bold text-2xl md:text-3xl text-zinc-900 dark:text-white mb-4 group-hover:text-accent transition-colors">{featuredPost.data.title}</h2>
                <p class="text-zinc-500 dark:text-zinc-400 leading-relaxed mb-6">{featuredPost.data.description}</p>
                <span class="inline-flex items-center gap-1.5 text-sm font-medium text-accent nav-link">Read article →</span>
              </div>
            </div>
          </a>
        </div>
      </section>
    )}

    <!-- ALL ARTICLES GRID -->
    <section class="pb-24">
      <div class="max-w-6xl mx-auto px-6">
        <div class="grid md:grid-cols-3 gap-6">
          {regularPosts.map((post, index) => (
            <BlogCard post={post} index={index} />
          ))}
        </div>

        <div id="no-articles" class="hidden text-center py-20">
          <p class="text-zinc-400 text-sm">No articles in this category yet.</p>
        </div>

        <!-- Pagination (Static for now as requested) -->
        <nav class="reveal flex items-center justify-center gap-2 mt-14" aria-label="Pagination">
          <span class="w-9 h-9 flex items-center justify-center rounded-full bg-accent text-white text-sm font-medium">1</span>
          <a href="#" class="w-9 h-9 flex items-center justify-center rounded-full border border-zinc-200 dark:border-zinc-800 text-zinc-600 dark:text-zinc-400 hover:border-accent hover:text-accent transition-colors text-sm">2</a>
          <a href="#" class="w-9 h-9 flex items-center justify-center rounded-full border border-zinc-200 dark:border-zinc-800 text-zinc-600 dark:text-zinc-400 hover:border-accent hover:text-accent transition-colors text-sm">3</a>
          <span class="text-zinc-400 text-sm px-1">…</span>
          <a href="#" class="w-9 h-9 flex items-center justify-center rounded-full border border-zinc-200 dark:border-zinc-800 text-zinc-600 dark:text-zinc-400 hover:border-accent hover:text-accent transition-colors text-sm">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </a>
        </nav>
      </div>
    </section>
  </div>

  <script>
    const filterBtns = document.querySelectorAll('.blog-filter-btn');
    const articles = document.querySelectorAll('.blog-article-wrapper');
    const noArticles = document.getElementById('no-articles');

    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        // Update active states
        filterBtns.forEach(b => {
          b.classList.remove('bg-accent', 'text-white', 'border-accent');
          b.classList.add('bg-white', 'dark:bg-zinc-900', 'text-zinc-600', 'dark:text-zinc-400', 'border-zinc-200', 'dark:border-zinc-700');
        });
        btn.classList.add('bg-accent', 'text-white', 'border-accent');
        btn.classList.remove('bg-white', 'dark:bg-zinc-900', 'text-zinc-600', 'dark:text-zinc-400', 'border-zinc-200', 'dark:border-zinc-700');

        const filter = btn.getAttribute('data-filter');
        let visibleCount = 0;

        articles.forEach(article => {
          const category = article.getAttribute('data-category');
          if (filter === 'all' || category === filter) {
            (article as HTMLElement).style.display = 'block';
            visibleCount++;
          } else {
            (article as HTMLElement).style.display = 'none';
          }
        });

        if (visibleCount === 0) {
          noArticles?.classList.remove('hidden');
        } else {
          noArticles?.classList.add('hidden');
        }
      });
    });
  </script>
</Layout>
