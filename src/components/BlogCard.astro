---
import type { CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import Tags from './Tags.astro';

interface Props {
  post: CollectionEntry<'blog'>;
  index?: number;
}

const { post, index = 0 } = Astro.props;
---

<article class={`reveal d${(index % 3) + 1} group bg-white dark:bg-zinc-900 rounded-2xl overflow-hidden border border-zinc-100 dark:border-zinc-800 hover:border-accent transition-all duration-300 hover:shadow-xl hover:shadow-black/5`}>
  <div class="relative aspect-video overflow-hidden">
    <Image 
      src={post.data.image} 
      alt={post.data.title} 
      width={600} 
      height={400} 
      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
      loading="lazy" 
    />
    <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
  </div>
  
  <div class="p-6">
    <div class="flex items-center gap-3 mb-4">
      <Tags tags={post.data.tags} />
      <span class="text-[10px] font-medium text-zinc-400 uppercase tracking-wider">
        {post.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
      </span>
    </div>

    <a href={`/blog/${post.id}`} class="block group/title">
      <h3 class="font-display font-bold text-xl text-zinc-900 dark:text-white mb-3 group-hover/title:text-accent transition-colors leading-tight">
        {post.data.title}
      </h3>
    </a>

    <p class="text-sm text-zinc-500 dark:text-zinc-400 leading-relaxed mb-6 line-clamp-2">
      {post.data.description}
    </p>

    <a href={`/blog/${post.id}`} class="inline-flex items-center gap-2 text-xs font-bold text-zinc-900 dark:text-white uppercase tracking-widest hover:text-accent transition-colors group/link">
      Read article 
      <svg class="w-3.5 h-3.5 transition-transform group-hover/link:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
      </svg>
    </a>
  </div>
</article>