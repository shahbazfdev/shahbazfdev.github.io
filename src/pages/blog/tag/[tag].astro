---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import BlogCard from '../../../components/BlogCard.astro';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog');
  
  // Extract unique tags
  const uniqueTags = [...new Set(allPosts.flatMap(post => post.data.tags || []))];

  return uniqueTags.map(tag => {
    const filteredPosts = allPosts.filter(post => post.data.tags?.includes(tag));
    return {
      params: { tag: tag.toLowerCase() },
      props: { posts: filteredPosts, tagName: tag },
    };
  });
}

const { tag } = Astro.params;
const { posts, tagName } = Astro.props;
---

<Layout title={`Articles tagged with #${tagName} — Shahbaz Fareed`}>
  <section class="pt-32 pb-24">
    <div class="max-w-6xl mx-auto px-6">
      <div class="mb-16">
        <a href="/blog" class="inline-flex items-center gap-2 text-sm text-zinc-500 dark:text-zinc-400 hover:text-accent transition-colors mb-6">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18" />
          </svg>
          Back to blog
        </a>
        <p class="text-xs font-medium text-accent tracking-widest uppercase mb-3">Topic</p>
        <h1 class="font-display font-bold text-4xl md:text-6xl text-zinc-900 dark:text-white capitalize">
          #{tagName}
        </h1>
        <p class="mt-6 text-lg text-zinc-500 dark:text-zinc-400 max-w-2xl">
          Showing {posts.length} {posts.length === 1 ? 'article' : 'articles'} filed under this tag.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        {posts.map((post, index) => (
          <BlogCard post={post} index={index} />
        ))}
      </div>
    </div>
  </section>
</Layout>
